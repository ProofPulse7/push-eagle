{%- if block.settings.enabled -%}
<div
  id="pe-prompt-{{ block.id }}"
  class="pe-prompt pe-prompt--{{ block.settings.position }}"
  hidden
  data-push-eagle-root
  data-enabled="true"
  data-mode="{{ block.settings.mode }}"
  data-app-url="https://push-eagle-dashboard.vercel.app"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-proxy-bootstrap-path="/apps/push-eagle/bootstrap"
  data-proxy-service-worker-path="/apps/push-eagle/sw.js"
  data-proxy-token-path="/apps/push-eagle/token"
  data-display-trigger="{{ block.settings.display_trigger | default: 'auto' | strip }}"
  data-manual-selector="{{ block.settings.manual_selector | escape }}"
  data-remind-after-days="{{ block.settings.remind_after_days }}"
  data-delay-ms="{{ block.settings.delay_seconds | times: 1000 }}"
  style="--pe-accent: {{ block.settings.accent_color }};"
  {{ block.shopify_attributes }}
>
  <div class="pe-prompt__card">
    <div class="pe-prompt__content">
      <div class="pe-prompt__logo-shell">
        <img class="pe-prompt__logo" data-push-eagle-logo alt="Push Eagle" width="48" height="48" hidden>
        <span class="pe-prompt__logo-fallback" data-push-eagle-logo-fallback aria-hidden="true">PE</span>
      </div>
      <div class="pe-prompt__copy">
        <p class="pe-prompt__headline" data-push-eagle-headline>{{ block.settings.headline }}</p>
        <p class="pe-prompt__subheading" data-push-eagle-message>{{ block.settings.subheading }}</p>
      </div>
    </div>
    <p class="pe-prompt__status" data-push-eagle-status aria-live="polite"></p>
    <div class="pe-prompt__actions">
      <button
        class="pe-prompt__btn pe-prompt__btn--primary"
        data-push-eagle-action
        type="button"
      >{{ block.settings.allow_label }}</button>
      <button
        class="pe-prompt__btn pe-prompt__btn--secondary"
        data-push-eagle-dismiss
        type="button"
      >{{ block.settings.decline_label }}</button>
    </div>
  </div>
</div>
{%- endif -%}

{{ 'push-eagle-widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'push-eagle-storefront.js' | asset_url }}" async defer></script>

{% schema %}
{
  "name": "Push Eagle Notifications",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable opt-in prompt",
      "default": true
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position on screen",
      "options": [
        { "value": "bottom-left",   "label": "Bottom left"   },
        { "value": "bottom-right",  "label": "Bottom right"  },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "top-left",      "label": "Top left"      },
        { "value": "top-right",     "label": "Top right"     }
      ],
      "default": "bottom-left"
    },
    {
      "type": "select",
      "id": "display_trigger",
      "label": "Show prompt",
      "options": [
        { "value": "auto",   "label": "Automatically after delay" },
        { "value": "manual", "label": "Only when visitor clicks a trigger element" }
      ],
      "default": "auto"
    },
    {
      "type": "text",
      "id": "manual_selector",
      "label": "Manual trigger CSS selector",
      "info": "Example: .js-enable-notifications or [data-push-eagle-open]",
      "default": "[data-push-eagle-open]"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Delay before showing (seconds)",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "remind_after_days",
      "label": "Show again after dismissing (days)",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 7
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Prompt style",
      "info": "Custom shows your branded card. Browser native uses the default browser dialog.",
      "options": [
        { "value": "custom",  "label": "Custom card (recommended)" },
        { "value": "browser", "label": "Browser native dialog" }
      ],
      "default": "custom"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get notified about exclusive offers, restocks, and updates — right in your browser."
    },
    {
      "type": "text",
      "id": "allow_label",
      "label": "Allow button text",
      "default": "Enable notifications"
    },
    {
      "type": "text",
      "id": "decline_label",
      "label": "Decline button text",
      "default": "Maybe later"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#9400D3"
    }
  ]
}
{% endschema %}

